# MySQL (Beekeeper / local). Create database first: CREATE DATABASE inrange;
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local XAMPP/WAMP often: user root, password root →
DATABASE_URL="mysql://root:root@localhost:3306/inrange"

NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@inrange.pk
ADMIN_PASSWORD=your-secure-password

# Server upload (admin products + checkout payment proof) — ye teen zaroori hain:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional (pehle unsigned client preset use hota tha; ab zaroorat nahi):
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

WHATSAPP_NUMBER=923001234567

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@inrange.pk

# Vendor portal (JWT + email; falls back to SMTP_* when EMAIL_* unset)
VENDOR_JWT_SECRET=generate-a-different-long-secret-from-nextauth
VENDOR_JWT_EXPIRES_IN=7d
# Set to "true" when vendor verification emails work. If unset/false, new vendors are
# marked email-verified at signup and only need admin approval before they can sign in.
VENDOR_REQUIRE_EMAIL_VERIFICATION=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
NEXT_PUBLIC_APP_URL=http://localhost:3000
